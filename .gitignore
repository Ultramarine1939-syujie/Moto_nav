# ==========================================
# 摩托车导航 moto-nav_v2 - .gitignore
# ==========================================

# ⚠️ 敏感配置文件 - 包含 API 密钥，绝对不能提交
config.js

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志
*.log
npm-debug.log*

# 依赖（如后续引入 npm）
node_modules/

# 构建产物
dist/
build/

# 环境变量文件（如后续迁移到 Node.js）
.env
.env.local
.env.*.local
